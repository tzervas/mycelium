# ---- Rust ----
/target/
**/target/
*.rs.bk
# Cargo.lock IS committed — the workspace ships a binary (`xtask`), so the lockfile is
# tracked for reproducible builds. (gitignore has no inline comments; keep this on its own line.)
*.pdb

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.uv/
.python-version
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ---- Haskell (LiquidHaskell proofs, cabal) ----
dist-newstyle/
.liquid/
*.hi
*.o
.ghc.environment.*

# ---- Tooling / verification scratch ----
*.smt2.out
*.cert.tmp
/scratch/
/.tmp/

# ---- Editors / OS ----
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
.DS_Store
Thumbs.db

# ---- Build/devcontainer ----
.devcontainer/.cache/

# ---- Claude Code / agent tooling (personal, machine-local) ----
.claude/settings.local.json
.claude/worktrees/
CLAUDE.local.md

# ---- Local check-tool installs ----
.tools-venv/
node_modules/

# ---- Secrets & credentials (NEVER commit) ----
# Local env files carry real keys (XAI_API_KEY, etc.) — ignore them, but KEEP the committed
# `.env.example` template (the negation below re-includes it; order matters).
.env
.env.*
!.env.example
# Private keys, certs, and credential blobs.
*.key
*.pem
*.p12
*.pfx
*.keystore
id_rsa
id_ed25519
*.crt
secrets.*
credentials.json
.netrc
