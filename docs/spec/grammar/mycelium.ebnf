(* Mycelium surface grammar — v0 (L1-facing fragment).
 *
 * Notation: W3C EBNF (as used by the XML 1.0 spec), NOT ISO 14977 (RFC-0006 §4.3 / T3.1-B;
 * Wheeler's critique). Terminals are 'quoted'; A? optional; A* zero-or-more; A+ one-or-more;
 * A | B alternation; (A B) grouping; /* ... */ comments. This artifact is the NORMATIVE oracle
 * for the accept/reject conformance corpus under ./conformance/ — every accept/ program parses
 * by this grammar, every reject/ program does not.
 *
 * Vocabulary is the ratified DN-02 set (Resolved 2026-06-10) plus `for` (RFC-0007 §4.8 r2;
 * recorded in DN-03) and the DN-06 static-organization lexicon (Resolved 2026-06-16): `nodule`
 * replaces the former static keyword `colony`. Themed keywords: nodule, substrate, spore, matured,
 * wild. Conventional: use, type, trait, fn, let, in, if, then, else, match, for, swap.
 *
 * RESERVED, NOT YET ACTIVE (DN-06): `phylum` (the library-scale grouping above nodules) and
 * `colony` (the dynamic runtime grouping of `hypha`, RFC-0008 §4.7) are reserved words — they lex
 * as keywords (so they are never silent identifiers) but no production consumes them yet, so neither
 * opens a program (see conformance/reject/10). They activate when their constructs land.
 *
 * This is v0 — it covers the L1-facing core (RFC-0006 §3 L1); abstraction/recursion typing,
 * the full trait/guild machinery (LR-2), and L2 sugar layer above it.
 *)

program        ::= nodule_header item*

nodule_header  ::= 'nodule' path

item           ::= use_item
                 | default_item
                 | type_item
                 | trait_item
                 | fn_item

use_item       ::= 'use' path

/* default paradigm: the nodule-scope ambient (RFC-0012 §4.2; enacted M-344). At most one per
 * nodule — the outermost ambient frame. It supplies an OMITTED paradigm for paradigm-less reprs
 * and bare decimals; it never inserts a swap (I1) and elaborates to the same L0 as the longhand
 * twin (I2). `default`/`paradigm`/`with` are reserved (DN-02 surface additions). */
default_item   ::= 'default' 'paradigm' paradigm
paradigm       ::= 'Binary' | 'Ternary' | 'Dense' | 'VSA'

/* Algebraic data type (LR-1): a sum of constructors, each with optional positional fields. */
type_item      ::= 'type' Ident type_params? '=' constructor ('|' constructor)*
type_params    ::= '<' Ident (',' Ident)* '>'
constructor    ::= Ident ('(' type_ref (',' type_ref)* ')')?

/* Trait = a named set of function signatures (LR-2; conventional term, DN-02). */
trait_item     ::= 'trait' Ident type_params? '{' fn_sig* '}'
fn_sig         ::= 'fn' Ident '(' params? ')' '->' type_ref

/* Function. 'matured' marks a promoted stable component (RFC-0004 §4; DN-02 themed term). */
fn_item        ::= 'matured'? 'fn' Ident type_params? '(' params? ')' '->' type_ref '=' expr
params         ::= param (',' param)*
param          ::= Ident ':' type_ref

/* Types. A guarantee-annotated type carries its honesty tag as a type-level index (LR-6). */
type_ref       ::= base_type ('@' strength)?
base_type      ::= 'Binary'  '{' Int '}'
                 | 'Ternary' '{' Int '}'
                 | 'Dense'   '{' Int ',' scalar '}'
                 | 'VSA'     '{' Ident ',' Int ',' sparsity '}'
                 | 'Substrate' '{' Ident '}'                  /* affine external resource (LR-8) */
                 | Ident type_args?                           /* named type or type variable */
                 | '{' ambient_params '}'                     /* paradigm-less repr (RFC-0012 §4.2) */
/* A paradigm-less repr writes the size/shape only; the enclosing ambient supplies the paradigm.
 * An ill-fitting shape is an explicit ParadigmShapeMismatch; no ambient is an UnresolvedAmbient. */
ambient_params ::= Int                                        /* Binary width / Ternary trit count */
                 | Int ',' scalar                             /* Dense shape */
                 | Ident ',' Int ',' sparsity                 /* VSA shape */
type_args      ::= '<' type_ref (',' type_ref)* '>'
sparsity       ::= 'Dense' | 'Sparse' '{' Int '}'
scalar         ::= 'F16' | 'BF16' | 'F32' | 'F64'
strength       ::= 'Exact' | 'Proven' | 'Empirical' | 'Declared'

/* Expressions. */
expr           ::= let_expr
                 | if_expr
                 | match_expr
                 | for_expr
                 | swap_expr
                 | with_expr
                 | wild_expr
                 | spore_expr
                 | app_expr

/* with paradigm: a block-scope ambient override (RFC-0012 §4.4; M-344). Not a conversion — it
 * fills the interior tags and elaborates away; a cross-paradigm edge in/out of the block needs an
 * explicit swap, and an unbridged one is a never-silent MissingConversion. */
with_expr      ::= 'with' 'paradigm' paradigm '{' expr '}'

let_expr       ::= 'let' Ident (':' type_ref)? '=' expr 'in' expr
if_expr        ::= 'if' expr 'then' expr 'else' expr
match_expr     ::= 'match' expr '{' arm (',' arm)* ','? '}'

/* for: bounded iteration — elaboration-defined sugar for a structurally-recursive fold over a
 * linearly recursive data value, Total by construction (RFC-0007 §4.8). The spelling is adopted
 * (r3; under the same global KC-2 gate as this whole grammar); `while`/`loop`/`break`/`continue`/
 * `return` are NOT forms and NOT reserved (they get teaching diagnostics where they already
 * error). */
for_expr       ::= 'for' Ident 'in' app_expr ',' Ident '=' app_expr '=>' expr
arm            ::= pattern '=>' expr
pattern        ::= '_'
                 | literal
                 | Ident ('(' pattern (',' pattern)* ')')?    /* constructor / binder */

/* swap: the never-silent representation change — target and policy ALWAYS lexical (S1/WF2). */
swap_expr      ::= 'swap' '(' expr ',' 'to' ':' type_ref ',' 'policy' ':' path ')'

/* wild: the denied-by-default unsafe escape hatch (LR-9/S6; DN-02 §5). */
wild_expr      ::= 'wild' '{' expr '}'

/* spore: build a reconstruction manifest for a value (RFC-0003 §6; DN-02 themed term). */
spore_expr     ::= 'spore' '(' expr ')'

/* Application / primary. Calls and atoms; ascription binds loosest. */
app_expr       ::= primary ('(' args? ')')* (':' type_ref)?
args           ::= expr (',' expr)*
primary        ::= literal
                 | path
                 | '(' expr ')'

path           ::= Ident ('.' Ident)*

/* Literals — representation-typed, universal-until-elaboration. A tagged literal (BinLit/TritLit)
 * names its paradigm; a bare Int has no representation family on its own (Q6) UNLESS an ambient is
 * in scope, in which case it adopts the ambient paradigm and takes its width from the checked
 * context, else an explicit UnresolvedWidth (RFC-0012 §4.3; M-344). */
literal        ::= BinLit | TritLit | Int | ListLit
ListLit        ::= '[' (expr (',' expr)*)? ']'

/* Terminals (lexer). */
BinLit         ::= '0b' ('0' | '1' | '_')+
TritLit        ::= '<' Trit+ '>'                     /* MSB-first balanced trits, compact */
Trit           ::= '+' | '0' | '-'
Int            ::= '-'? [0-9]+
Ident          ::= (Letter | '_') (Letter | [0-9] | '_')*
Letter         ::= [a-zA-Z]

/* Comments: line comments start with '//' and run to end-of-line; ignored by the grammar. */
