[codespell]
# Spell-check prose. Add genuine false positives to ignore-words-list (comma-separated,
# lowercase). Keep this list small and justified.
# fuzz/corpus/* is fuzzer input/output data (committed seeds + libFuzzer-generated mutations) —
# raw bytes, never prose, so it is skipped like target/ and the harness reports (M-654).
# mutants.out / mutants.out.old is a local `cargo-mutants` run's output dir (gitignored, but codespell
# walks the filesystem and does not honour .gitignore — it is generated logs/diffs, never prose).
# *package-lock.json is a generated npm dependency lockfile (base64 integrity hashes, never prose —
# a substring `vEw` of one SHA-512 hash false-flags as "view/vow/vex"); skipped like *.lock.
skip = .git,*.lock,*package-lock.json,node_modules,target,dist-newstyle,.venv,.tools-venv,*.svg,idmap.tsv,./tools/llm-harness/reports/*,tools/llm-harness/reports/*,./fuzz/corpus/*,fuzz/corpus/*,mutants.out,mutants.out.old,./mutants.out/*,mutants.out/*
# Domain terms / abbreviations codespell otherwise flags:
# ser (Serialize abbrev), clen (Content-Length var), publisherr (PublishErr type), raison (raison
# d'être), copyed/copys (Dockerfile COPY directive), re-used (valid hyphenation).
# Additional justified false positives (domain terms / proper nouns / valid hyphenation):
# theses (real word + a URL path segment), forin (Lean 4 `ForIn` typeclass name), symantics
# (the tagless-final "Symantics" typeclass, a deliberate Syntax/semantics pun — Carette/Kiselyov/
# Shan), generat (bracketed quote insertion "generat[es]"), disjointness (valid set-theory term;
# codespell mis-suggests "disjointedness"), toom (Toom-Cook multiplication algorithm), pre-emptive
# and re-declare (valid hyphenations). unparseable (valid English variant of "unparsable",
# used in scripts/hooks/test-branch-guard-parse.sh). rouge (the Ruby syntax-highlighter gem
# rouge-ruby/rouge — GitLab's highlighter, named in the editor-grammar distribution runbook; NOT
# "rogue"). notin (the VS Code language-configuration.json schema key `notIn` — a required literal,
# not renamable; used by editors/vscode).
# deques (work-stealing deques — standard CS term; mycelium-sched/DN-67/issues.yaml), nd/thw/lits
# (identifier fragments in the self-hosted lib/compiler/*.myc ports + their Rust test mirrors —
# split-match helper names and prefixed constructors, never prose). bloc (a "bloc" of gaps — the
# political/grouping sense, not "block"; DN-34). numer (short for numerator; mycelium-tero verdict.rs).
# abd (a `glob_match` literal-set test fixture "a[bc]d" -> "abd"/"acd", crates/mycelium-doc/src/tests/book.rs
# — not the word "and"). caf (the first 3 ASCII bytes of "café" split across a `\u{00e9}` escape in two
# mycelium-doc non-ASCII-handling test fixtures — highlight.rs's fallback test, inline.rs's UTF-8-safe
# slicing test — not the word "calf"). mis (the parenthetical clarification "originally
# (mis)claimed" in checkty.rs's HOLE-A2 doc comment, mirrored verbatim into the gen/myc-drafts
# semcore .gap.json snippets — valid English word-fragment usage, not a typo). re-declared (the
# past-tense inflection of the already-ignored re-declare, DN-122 §2's "a local trait Widen
# re-declared per file" — valid hyphenation).
ignore-words-list = crate,crates,iff,ist,nin,ba,te,fo,mor,ans,od,implementor,implementors,referenced,effekt,inout,ser,clen,publisherr,raison,copyed,copys,re-use,re-used,re-uses,ot,theses,forin,symantics,generat,disjointness,toom,pre-emptive,re-declare,olt,unparseable,rouge,notin,retuned,deques,nd,thw,lits,bloc,numer,re-using,pre-empts,re-declares,abd,caf,mis,re-declared
quiet-level = 3
