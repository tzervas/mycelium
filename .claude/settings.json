{
  "worktree": {
    "baseRef": "head"
  },
  "permissions": {
    "allow": [
      "Bash(git commit --no-verify:*)",
      "Bash(git push --no-verify:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/scripts/hooks/claude-git-branch-guard.sh\""
          }
        ]
      }
    ]
  }
}
