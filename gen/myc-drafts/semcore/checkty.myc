// nodule: l1.checkty
// The **v0 monomorphic typechecker** (RFC-0007 ¬ß4.4) plus the program environment it checks
// against: the data-type registry (declarations are registry entries, never term nodes ‚Äî
// RFC-0007 ¬ß4.2) and the function table. Every refusal is an explicit [`CheckError`] ‚Äî generics,
// `spore`, value-level integers without context, and a `wild` block outside the audited FFI floor
// (the `@std-sys` context gate, M-661/LR-9) are *refused with a reason*, never guessed at. A `wild`
// inside a `@std-sys` nodule is the audited FFI escape: gated (it must declare the `ffi` effect),
// its body trusted/opaque (not recursively checked ‚Äî audited, not verified, VR-5/ADR-014), and its
// execution staged ([`crate::elab`] lowers it to a `Residual`).
// @summary: best-effort transpilation via mycelium-transpile (M-873). Declared,
// unvalidated ‚Äî no Mycelium parser/typechecker confirms this output; see the
// accompanying .gap.json for every construct this pass could not express.
nodule l1.checkty;

// A width argument in a [`Ty::Binary`] or [`Ty::Ternary`] ‚Äî either a concrete literal or an
// abstract width parameter (DN-42 / M-753). Width variables (`Var`) are introduced in step (b)
// and survive only during generic-fn checking; they must not reach elaboration.
pub type Width = Lit(Binary{32}) | Var(Bytes);

// An explicit check failure (never a silent pass or a guess ‚Äî S5/G2).
pub type CheckError = CheckError(Bytes, Bytes);

// What introduced a performed effect, for the coverage diagnostic. `Ord` so the `(effect, source)`
// set is deterministic (a stable first-miss). A **`Call`** is a top-level fn or trait-method call
// (M-660); **`Wild`** is the `wild` FFI floor (M-661 ‚Äî `wild` performs `ffi`).
type EffectSource = Call(Bytes) | Wild;

// A minimal, per-call fresh-name generator for [`Cx::stage3_substitute_expr`]'s (A)-style
// RHS-local-binder renaming (M-1054 Stage 3, DN-117 ¬ß2 step 1) ‚Äî the check-time-only analogue of
// [`crate::elab::Elab::fresh`]. `%`-prefixed (surface-illegal ‚Äî `crate::lexer::is_ident_start`
// forbids `%`, mirrored by every other synthetic-name scheme in this module/`elab.rs`), so a
// minted name can never collide with a real surface identifier; the counter makes distinct mints
// within one substitution walk distinct from each other. Not persisted past one
// `check_sugar_call` invocation ‚Äî a fresh instance every time (no cross-call state, unlike
// `elab.rs`'s `SUGAR_EXPANSION_SITE`, which needs cross-invocation uniqueness for the *real*,
// elaboration-time expansion; this walk's renamed binders are discarded with the rest of the
// substituted term).
type Stage3Fresh = Stage3Fresh(Binary{64});

// **M-1054 Stage 2 (G1, DN-115 ¬ß4.1)** ‚Äî a pure **name** predicate ("is `name` any kernel-
// recognized prim at all", ignoring argument shape) covering every dispatcher [`Cx::check_app`]
// tries: the width-preserving [`prim_family`] set, plus [`VSA_PRIM_NAMES`] and the float-prim
// groups via [`float_prim_name_is_recognized`] (the two argument-shape-matching dispatchers ‚Äî
// [`Cx::try_check_vsa_prim`] / [`Cx::try_check_float_prim`] ‚Äî have no name-only view of their own;
// this is that view). Used by [`Cx::rhs_first_free_id`] to close the over-refusal gap DN-115 ¬ß4.1
// flags: previously only `prim_family` was consulted there, so a legitimate VSA/float prim in a
// `lower`-rule RHS was wrongly refused as a free identifier even though [`Cx::check_app`] would
// have resolved it fine at an ordinary call site.
fn prim_name_is_recognized(name: Bytes) => Bool = is_some(prim_family(name)) || contains(VSA_PRIM_NAMES, name) || float_prim_name_is_recognized(name);
